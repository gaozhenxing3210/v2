#!/bin/sh
set -eu

CONF="/etc/v2raya-dns-policy.conf"
[ -f "$CONF" ] && . "$CONF"

: "${ENABLE_DNS_POLICY:=1}"
: "${LAN_IF:=br-lan}"
NFT="/usr/sbin/nft"
[ -x "$NFT" ] || NFT="nft"
IPTABLES="/usr/sbin/iptables"
[ -x "$IPTABLES" ] || IPTABLES="iptables"
TABLE_FAMILY="inet"
TABLE_NAME="codex_v2raya_dns"
CHAIN_NAME="dstnat"
COMMENT_TAG="codex-v2raya-dns-policy"
LEGACY_CHAIN="CODEX_V2RAYA_DNS"
LAN_IP="$(uci -q get network.lan.ipaddr 2>/dev/null || echo 192.168.1.1)"
SOCKS_DNS_REDIRECTS="/tmp/v2raya-socks-dns.redirects.tsv"

ensure_table() {
  $NFT list table "$TABLE_FAMILY" "$TABLE_NAME" >/dev/null 2>&1 || $NFT add table "$TABLE_FAMILY" "$TABLE_NAME"
  $NFT list chain "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN_NAME" >/dev/null 2>&1 || \
    $NFT add chain "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN_NAME" "{ type nat hook prerouting priority dstnat; policy accept; }"
}

remove_table() {
  $NFT delete table "$TABLE_FAMILY" "$TABLE_NAME" >/dev/null 2>&1 || true
}

ensure_legacy_chain() {
  $IPTABLES -w 2 -t nat -N "$LEGACY_CHAIN" 2>/dev/null || true
  $IPTABLES -w 2 -t nat -C PREROUTING -i "$LAN_IF" -p udp --dport 53 -j "$LEGACY_CHAIN" 2>/dev/null || \
    $IPTABLES -w 2 -t nat -I PREROUTING 1 -i "$LAN_IF" -p udp --dport 53 -j "$LEGACY_CHAIN"
  $IPTABLES -w 2 -t nat -C PREROUTING -i "$LAN_IF" -p tcp --dport 53 -j "$LEGACY_CHAIN" 2>/dev/null || \
    $IPTABLES -w 2 -t nat -I PREROUTING 1 -i "$LAN_IF" -p tcp --dport 53 -j "$LEGACY_CHAIN"
}

remove_legacy_chain() {
  $IPTABLES -w 2 -t nat -D PREROUTING -i "$LAN_IF" -p udp --dport 53 -j "$LEGACY_CHAIN" 2>/dev/null || true
  $IPTABLES -w 2 -t nat -D PREROUTING -i "$LAN_IF" -p tcp --dport 53 -j "$LEGACY_CHAIN" 2>/dev/null || true
  $IPTABLES -w 2 -t nat -F "$LEGACY_CHAIN" 2>/dev/null || true
  $IPTABLES -w 2 -t nat -X "$LEGACY_CHAIN" 2>/dev/null || true
}

if [ "$ENABLE_DNS_POLICY" != "1" ]; then
  remove_table
  remove_legacy_chain
  exit 0
fi

if command -v "$NFT" >/dev/null 2>&1; then
  remove_legacy_chain
  ensure_table
  $NFT flush chain "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN_NAME"
  if [ -f "$SOCKS_DNS_REDIRECTS" ]; then
    while IFS="$(printf '\t')" read -r ip port; do
      case "$ip" in *.*.*.*) ;; *) continue ;; esac
      case "$port" in ''|*[!0-9]*) continue ;; esac
      $NFT add rule "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN_NAME" iifname "$LAN_IF" ip saddr "$ip" udp dport 53 counter redirect to :"$port" comment "$COMMENT_TAG-socks"
      $NFT add rule "$TABLE_FAMILY" "$TABLE_NAME" "$CHAIN_NAME" iifname "$LAN_IF" ip saddr "$ip" tcp dport 53 counter redirect to :"$port" comment "$COMMENT_TAG-socks"
    done < "$SOCKS_DNS_REDIRECTS"
  fi
else
  remove_table
  ensure_legacy_chain
  $IPTABLES -w 2 -t nat -F "$LEGACY_CHAIN"
  $IPTABLES -w 2 -t nat -A "$LEGACY_CHAIN" -d "$LAN_IP" -j RETURN
  if [ -f "$SOCKS_DNS_REDIRECTS" ]; then
    while IFS="$(printf '\t')" read -r ip port; do
      case "$ip" in *.*.*.*) ;; *) continue ;; esac
      case "$port" in ''|*[!0-9]*) continue ;; esac
      $IPTABLES -w 2 -t nat -A "$LEGACY_CHAIN" -s "$ip" -p udp --dport 53 -j REDIRECT --to-ports "$port"
      $IPTABLES -w 2 -t nat -A "$LEGACY_CHAIN" -s "$ip" -p tcp --dport 53 -j REDIRECT --to-ports "$port"
    done < "$SOCKS_DNS_REDIRECTS"
  fi
fi
