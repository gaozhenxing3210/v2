#!/bin/sh
set -eu
AUTH="/etc/v2raya-policy.auth"
[ -f "$AUTH" ] && . "$AUTH"
: "${V2RAYA_API:=http://127.0.0.1:2017}"
: "${V2RAYA_USER:=admin}"
: "${V2RAYA_PASS:=weifeng}"
MAP="/etc/v2raya-policy.map"
/usr/libexec/v2raya-policy-build.lua
ALLOW_MACS="$(cat /tmp/v2raya-policy.allow-macs 2>/dev/null || true)"
COUNT="$(cat /tmp/v2raya-policy.active-count 2>/dev/null || echo 0)"
setting_needs_sync() {
  lua - "$1" "$2" <<'LUA'
local json = require "luci.jsonc"
local desired_path, current_path = arg[1], arg[2]
local function read_json(path)
  local f = io.open(path, "r")
  local s = f and f:read("*a") or ""
  if f then f:close() end
  return json.parse(s) or {}
end
local desired = read_json(desired_path)
local current = read_json(current_path)
current = current.data and current.data.setting or current.setting or current or {}
for k, v in pairs(desired) do
  if tostring(current[k]) ~= tostring(v) then
    print("1")
    return
  end
end
print("0")
LUA
}
{
  echo '# v2rayA device allowlist'
  echo '# Managed by /cgi-bin/v2raya-policy.'
  echo 'LAN_IF="br-lan"'
  printf 'ALLOW_MACS="%s"\n' "$ALLOW_MACS"
} > /etc/v2raya-device-policy.conf
chmod 644 /etc/v2raya-device-policy.conf
if [ -s "$MAP" ]; then
  awk '!/^#/ && NF>=3 {print $1, $2}' "$MAP" | while read mac ip; do
    case "$mac" in ''|*[!0-9a-fA-F:]*) continue ;; esac
    case "$ip" in *.*.*.*) ;; *) continue ;; esac
    if ! uci show dhcp 2>/dev/null | grep -qi "mac='$mac'"; then
      s="$(uci add dhcp host)"
      uci set dhcp.$s.name="v2raya-$(echo "$mac" | tr ':' '-')"
      uci set dhcp.$s.mac="$mac"
      uci set dhcp.$s.ip="$ip"
      uci commit dhcp
    fi
  done
  /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
  /etc/init.d/odhcpd reload >/dev/null 2>&1 || true
fi
tmp_login="/tmp/v2raya-login.$$"
lua - "$V2RAYA_USER" "$V2RAYA_PASS" > "$tmp_login" <<'LUA'
local json = require "luci.jsonc"
print(json.stringify({ username = arg[1] or "", password = arg[2] or "" }))
LUA
login_json="$(curl -fsS -m 10 -H 'Content-Type: application/json' --data-binary @"$tmp_login" "$V2RAYA_API/api/login" || true)"
rm -f "$tmp_login"
token="$(printf '%s' "$login_json" | jsonfilter -q -e '@.data.token' 2>/dev/null || true)"
if [ -n "$token" ]; then
  tmp_touch="/tmp/v2raya-apply-touch.$$"
  tmp_setting="/tmp/v2raya-apply-setting.$$"
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/touch" > "$tmp_touch" 2>/dev/null || echo '{}' > "$tmp_touch"
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/setting" > "$tmp_setting" 2>/dev/null || echo '{}' > "$tmp_setting"
  running="$(jsonfilter -q -i "$tmp_touch" -e '@.data.running' 2>/dev/null || echo false)"
  sync_setting="$(setting_needs_sync /etc/v2raya-policy.setting.json "$tmp_setting" 2>/dev/null || echo 1)"
  rm -f "$tmp_touch" "$tmp_setting"
  curl -fsS -m 10 -X PUT -H 'Content-Type: application/json' -H "Authorization: $token" --data-binary @/tmp/v2raya-policy.routing.json "$V2RAYA_API/api/routingA" >/dev/null || true
  if [ "$sync_setting" = "1" ]; then
    # Write RoutingA first, then sync the desired v2rayA setting once so the core rebuild sees the latest source-IP rules.
    curl -fsS -m 10 -X PUT -H 'Content-Type: application/json' -H "Authorization: $token" --data-binary @/etc/v2raya-policy.setting.json "$V2RAYA_API/api/setting" >/dev/null || true
  fi
  if [ "$COUNT" -gt 0 ] && { [ "$sync_setting" != "1" ] || [ "$running" != "true" ]; }; then
    curl -fsS -m 20 -X POST -H 'Content-Type: application/json' -H "Authorization: $token" -d '{}' "$V2RAYA_API/api/v2ray" >/dev/null || true
  fi
fi
/usr/bin/v2raya-device-policy >/dev/null 2>&1 || true
