#!/bin/sh
set -eu
AUTH="/etc/v2raya-policy.auth"
[ -f "$AUTH" ] && . "$AUTH"
: "${V2RAYA_API:=http://127.0.0.1:2017}"
: "${V2RAYA_USER:=admin}"
: "${V2RAYA_PASS:=weifeng}"
MAP="/etc/v2raya-policy.map"
HOST_SYNC="/tmp/v2raya-policy.hosts.tsv"
DEVICE_DNS_CONF="/tmp/dnsmasq.d/v2raya-device-dns.conf"
DNS_BYPASS_SYNC="/tmp/v2raya-device-dns-bypass.tsv"
DEVICE_DNS_SERVERS="${DEVICE_DNS_SERVERS:-8.8.8.8,1.1.1.1}"
/usr/libexec/v2raya-policy-build.lua
ALLOW_MACS="$(cat /tmp/v2raya-policy.allow-macs 2>/dev/null || true)"
COUNT="$(cat /tmp/v2raya-policy.active-count 2>/dev/null || echo 0)"
write_if_changed() {
  local target="$1" tmp="$2"
  mkdir -p "$(dirname "$target")"
  if [ ! -f "$target" ] || ! cmp -s "$tmp" "$target" 2>/dev/null; then
    cp "$tmp" "$target"
    return 0
  fi
  return 1
}
find_dhcp_host_section_by_mac() {
  local mac_lc="$1"
  uci show dhcp 2>/dev/null | awk -v m="$mac_lc" '
    BEGIN { IGNORECASE=1; sec="" }
    /^dhcp\.[^=]+=host$/ {
      split($0, a, "=")
      sec=a[1]
      sub(/^dhcp\./, "", sec)
      next
    }
    index(tolower($0), ".mac='\''" tolower(m) "'\''") > 0 {
      print sec
      exit
    }
  '
}
setting_needs_sync() {
  lua - "$1" "$2" <<'LUA'
local json = require "luci.jsonc"
local desired_path, current_path = arg[1], arg[2]
local function read_json(path)
  local f = io.open(path, "r")
  local s = f and f:read("*a") or ""
  if f then f:close() end
  return json.parse(s) or {}
end
local desired = read_json(desired_path)
local current = read_json(current_path)
current = current.data and current.data.setting or current.setting or current or {}
for k, v in pairs(desired) do
  if tostring(current[k]) ~= tostring(v) then
    print("1")
    return
  end
end
print("0")
LUA
}
find_placeholder_ref() {
  lua - "$1" <<'LUA'
local json = require "luci.jsonc"
local f = io.open(arg[1], "r")
local obj = json.parse(f and f:read("*a") or "{}") or {}
if f then f:close() end
local touch = obj.data and obj.data.touch or {}
for _, s in ipairs(touch.servers or {}) do
  if tostring(s.address or ""):match("^1%.1%.1%.1") then
    print("server|" .. tostring(s.id) .. "|0")
    return
  end
end
LUA
}
find_connected_ref() {
  lua - "$1" "$2" <<'LUA'
local json = require "luci.jsonc"
local f = io.open(arg[1], "r")
local obj = json.parse(f and f:read("*a") or "{}") or {}
if f then f:close() end
local outbound = arg[2] or ""
local touch = obj.data and obj.data.touch or {}
for _, c in ipairs(touch.connectedServer or {}) do
  if tostring(c.outbound or "") == outbound then
    print(tostring(c._type or "server") .. "|" .. tostring(c.id or "") .. "|" .. tostring(c.sub or 0))
    return
  end
end
LUA
}
ensure_placeholder_ref() {
  local touch_file="$1"
  local placeholder_ref tmp_ph_link tmp_ph_payload
  placeholder_ref="$(find_placeholder_ref "$touch_file")"
  if [ -n "$placeholder_ref" ]; then
    printf '%s' "$placeholder_ref"
    return 0
  fi
  tmp_ph_link="/tmp/v2raya-placeholder-link.$$"
  tmp_ph_payload="/tmp/v2raya-placeholder-payload.$$"
  printf 'socks5://1.1.1.1:1#VIRTUAL-PLACEHOLDER' > "$tmp_ph_link"
  lua - "$tmp_ph_link" > "$tmp_ph_payload" <<'LUA'
local json = require "luci.jsonc"
local f = io.open(arg[1], "r")
local link = f and (f:read("*a") or "") or ""
if f then f:close() end
print(json.stringify({ links = { link } }))
LUA
  curl -fsS -m 20 -H 'Content-Type: application/json' -H "Authorization: $token" --data-binary @"$tmp_ph_payload" "$V2RAYA_API/api/link" >/dev/null 2>&1 || true
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/touch" > "$touch_file" 2>/dev/null || echo '{}' > "$touch_file"
  rm -f "$tmp_ph_link" "$tmp_ph_payload"
  find_placeholder_ref "$touch_file"
}
bind_outbound_ref() {
  local outbound="$1" id="$2" typ="$3" sub="$4" payload resp code
  payload="{\"id\":$id,\"_type\":\"$typ\",\"sub\":$sub,\"outbound\":\"$outbound\"}"
  resp="$(curl -fsS -m 25 -H 'Content-Type: application/json' -H "Authorization: $token" -d "$payload" "$V2RAYA_API/api/connection" || true)"
  code="$(printf '%s' "$resp" | jsonfilter -q -e '@.code' 2>/dev/null || true)"
  [ "$code" = "SUCCESS" ]
}
sync_unbound_outbounds_to_placeholder() {
  local touch_file="$1" placeholder_ref ph_typ ph_id ph_sub used_file current_ref outbound
  placeholder_ref="$(ensure_placeholder_ref "$touch_file")"
  [ -n "$placeholder_ref" ] || return 0
  ph_typ="$(echo "$placeholder_ref" | cut -d'|' -f1)"
  ph_id="$(echo "$placeholder_ref" | cut -d'|' -f2)"
  ph_sub="$(echo "$placeholder_ref" | cut -d'|' -f3)"
  used_file="/tmp/v2raya-policy-used-outbounds.$$"
  awk '!/^#/ && NF>=3 && $3 ~ /^dev[0-9][0-9]$/ {print $3}' "$MAP" 2>/dev/null | sort -u > "$used_file"
  for n in $(seq -w 1 20); do
    outbound="dev$n"
    grep -qx "$outbound" "$used_file" 2>/dev/null && continue
    current_ref="$(find_connected_ref "$touch_file" "$outbound")"
    [ "$current_ref" = "$placeholder_ref" ] && continue
    bind_outbound_ref "$outbound" "$ph_id" "$ph_typ" "$ph_sub" >/dev/null 2>&1 || true
  done
  rm -f "$used_file"
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/touch" > "$touch_file" 2>/dev/null || echo '{}' > "$touch_file"
}
{
  echo '# v2rayA device allowlist'
  echo '# Managed by /cgi-bin/v2raya-policy.'
  echo 'LAN_IF="br-lan"'
  printf 'ALLOW_MACS="%s"\n' "$ALLOW_MACS"
} > /etc/v2raya-device-policy.conf
chmod 644 /etc/v2raya-device-policy.conf
{
  echo '# v2rayA dns policy'
  echo '# Managed by /cgi-bin/v2raya-policy.'
  echo 'ENABLE_DNS_POLICY="0"'
  echo 'LAN_IF="br-lan"'
  printf 'DEVICE_DNS_SERVERS="%s"\n' "$DEVICE_DNS_SERVERS"
  printf 'DEVICE_DNS_BYPASS_LIST="%s"\n' "$DNS_BYPASS_SYNC"
} > /etc/v2raya-dns-policy.conf
chmod 644 /etc/v2raya-dns-policy.conf
dhcp_changed=0
dns_cfg_changed=0
tmp_dns_conf="/tmp/v2raya-device-dns.conf.$$"
tmp_bypass="/tmp/v2raya-device-dns-bypass.tsv.$$"
device_dns_count=0
{
  echo '# v2rayA per-device DNS'
  echo '# Managed by /cgi-bin/v2raya-policy.'
} > "$tmp_dns_conf"
: > "$tmp_bypass"
if [ -s "$HOST_SYNC" ]; then
  while IFS="$(printf '\t')" read mac ip; do
    case "$mac" in ''|*[!0-9a-fA-F:]*) continue ;; esac
    case "$ip" in *.*.*.*) ;; *) continue ;; esac
    s="$(find_dhcp_host_section_by_mac "$mac" || true)"
    if [ -z "$s" ]; then
      s="$(uci add dhcp host)"
    fi
    uci set dhcp.$s.name="v2raya-$(echo "$mac" | tr ':' '-')"
    uci set dhcp.$s.mac="$mac"
    uci set dhcp.$s.ip="$ip"
    dhcp_changed=1
    tag="v2p_$(echo "$mac" | tr 'A-F:' 'a-f_' | tr -cd '0-9a-z_')"
    printf 'dhcp-mac=set:%s,%s\n' "$tag" "$mac" >> "$tmp_dns_conf"
    printf 'dhcp-option=tag:%s,6,%s\n' "$tag" "$DEVICE_DNS_SERVERS" >> "$tmp_dns_conf"
    printf '%s\n' "$ip" >> "$tmp_bypass"
    device_dns_count=$((device_dns_count + 1))
  done < "$HOST_SYNC"
fi
if [ "$device_dns_count" -gt 0 ]; then
  write_if_changed "$DEVICE_DNS_CONF" "$tmp_dns_conf" && dns_cfg_changed=1 || true
  write_if_changed "$DNS_BYPASS_SYNC" "$tmp_bypass" >/dev/null 2>&1 || true
else
  [ -f "$DEVICE_DNS_CONF" ] && rm -f "$DEVICE_DNS_CONF" && dns_cfg_changed=1 || true
  [ -f "$DNS_BYPASS_SYNC" ] && rm -f "$DNS_BYPASS_SYNC" || true
fi
rm -f "$tmp_dns_conf" "$tmp_bypass"
if [ "$dhcp_changed" = "1" ] || [ "$dns_cfg_changed" = "1" ]; then
  uci commit dhcp
  /etc/init.d/dnsmasq restart >/dev/null 2>&1 || /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
  /etc/init.d/odhcpd reload >/dev/null 2>&1 || true
fi
tmp_login="/tmp/v2raya-login.$$"
lua - "$V2RAYA_USER" "$V2RAYA_PASS" > "$tmp_login" <<'LUA'
local json = require "luci.jsonc"
print(json.stringify({ username = arg[1] or "", password = arg[2] or "" }))
LUA
login_json="$(curl -fsS -m 10 -H 'Content-Type: application/json' --data-binary @"$tmp_login" "$V2RAYA_API/api/login" || true)"
rm -f "$tmp_login"
token="$(printf '%s' "$login_json" | jsonfilter -q -e '@.data.token' 2>/dev/null || true)"
if [ -n "$token" ]; then
  tmp_touch="/tmp/v2raya-apply-touch.$$"
  tmp_setting="/tmp/v2raya-apply-setting.$$"
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/touch" > "$tmp_touch" 2>/dev/null || echo '{}' > "$tmp_touch"
  curl -fsS -m 10 -H "Authorization: $token" "$V2RAYA_API/api/setting" > "$tmp_setting" 2>/dev/null || echo '{}' > "$tmp_setting"
  sync_unbound_outbounds_to_placeholder "$tmp_touch"
  running="$(jsonfilter -q -i "$tmp_touch" -e '@.data.running' 2>/dev/null || echo false)"
  sync_setting="$(setting_needs_sync /etc/v2raya-policy.setting.json "$tmp_setting" 2>/dev/null || echo 1)"
  rm -f "$tmp_touch" "$tmp_setting"
  curl -fsS -m 10 -X PUT -H 'Content-Type: application/json' -H "Authorization: $token" --data-binary @/tmp/v2raya-policy.routing.json "$V2RAYA_API/api/routingA" >/dev/null || true
  if [ "$sync_setting" = "1" ]; then
    # Write RoutingA first, then sync the desired v2rayA setting once so the core rebuild sees the latest source-IP rules.
    curl -fsS -m 10 -X PUT -H 'Content-Type: application/json' -H "Authorization: $token" --data-binary @/etc/v2raya-policy.setting.json "$V2RAYA_API/api/setting" >/dev/null || true
  fi
  if [ "$COUNT" -gt 0 ] && { [ "$sync_setting" != "1" ] || [ "$running" != "true" ]; }; then
    curl -fsS -m 20 -X POST -H 'Content-Type: application/json' -H "Authorization: $token" -d '{}' "$V2RAYA_API/api/v2ray" >/dev/null || true
  fi
fi
/usr/bin/v2raya-device-policy >/dev/null 2>&1 || true
/usr/bin/v2raya-socks-dns stop >/dev/null 2>&1 || true
/usr/bin/v2raya-dns-policy >/dev/null 2>&1 || true
/usr/bin/v2raya-socks-compat stop >/dev/null 2>&1 || true
