#!/bin/sh
set -eu

CONFIG="/etc/v2raya/config.json"
MAP="/etc/v2raya-policy.map"
LEASE="/tmp/dhcp.leases"
NFT="/usr/sbin/nft"
[ -x "$NFT" ] || NFT="nft"
IPTABLES="/usr/sbin/iptables"
[ -x "$IPTABLES" ] || IPTABLES="iptables"
COMMENT_TAG="codex-v2raya-socks-compat"

collect_socks_ips() {
  lua - "$CONFIG" "$MAP" "$LEASE" <<'LUA'
local json = require "luci.jsonc"
local config_path, map_path, lease_path = arg[1], arg[2], arg[3]

local function readfile(path)
  local f = io.open(path, "r")
  if not f then return "" end
  local s = f:read("*a") or ""
  f:close()
  return s
end

local function trim(s)
  return (tostring(s or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

local function norm_mac(s)
  return trim(s):lower():gsub("[^0-9a-f:]", "")
end

local function valid_ip(ip)
  return trim(ip):match("^%d+%.%d+%.%d+%.%d+$") ~= nil
end

local cfg = json.parse(readfile(config_path)) or {}
local socks = {}
for _, ob in ipairs(cfg.outbounds or {}) do
  local tag = trim(ob.tag)
  local proto = trim(ob.protocol):lower()
  local server = (((ob.settings or {}).servers or {})[1] or {})
  if tag ~= "" and proto == "socks" and not tostring(server.address or ""):match("^1%.1%.1%.1$") then
    socks[tag] = true
  end
end

local leases = {}
for line in readfile(lease_path):gmatch("[^\n]+") do
  local _, mac, ip = line:match("^(%S+)%s+(%S+)%s+(%S+)")
  mac = norm_mac(mac)
  if mac ~= "" and valid_ip(ip) then
    leases[mac] = ip
  end
end

local seen = {}
for line in readfile(map_path):gmatch("[^\n]+") do
  line = trim((line:gsub("#.*$", "")))
  if line ~= "" then
    local mac, ip, outbound = line:match("^(%S+)%s+(%S+)%s+(%S+)")
    mac = norm_mac(mac)
    ip = trim(ip)
    outbound = trim(outbound)
    if leases[mac] and valid_ip(leases[mac]) then
      ip = leases[mac]
    end
    if socks[outbound] and valid_ip(ip) and not seen[ip] then
      seen[ip] = true
      print(ip)
    end
  end
end
LUA
}

apply_iptables() {
  $IPTABLES -t mangle -S TP_RULE >/dev/null 2>&1 || return 0
  remove_iptables
  collect_socks_ips | while IFS= read -r ip; do
    [ -n "$ip" ] || continue
    $IPTABLES -w 2 -t mangle -I TP_RULE 1 -s "$ip" -p udp ! --dport 53 -m comment --comment "$COMMENT_TAG" -j RETURN
  done
}

remove_iptables() {
  while true; do
    line="$($IPTABLES -w 2 -t mangle -S TP_RULE 2>/dev/null | grep -- "-m comment --comment $COMMENT_TAG" | head -n 1 || true)"
    [ -n "$line" ] || break
    $IPTABLES -w 2 -t mangle ${line/-A/-D} >/dev/null 2>&1 || break
  done
}

apply_nft() {
  $NFT list chain inet v2raya tp_pre >/dev/null 2>&1 || return 0
  remove_nft
  collect_socks_ips | while IFS= read -r ip; do
    [ -n "$ip" ] || continue
    $NFT insert rule inet v2raya tp_pre ip saddr "$ip" udp dport != 53 counter return comment "$COMMENT_TAG"
  done
}

remove_nft() {
  $NFT -a list chain inet v2raya tp_pre 2>/dev/null | awk '/codex-v2raya-socks-compat/ {print $NF}' | while read -r handle; do
    case "$handle" in ''|*[!0-9]*) continue ;; esac
    $NFT delete rule inet v2raya tp_pre handle "$handle" 2>/dev/null || true
  done
}

case "${1:-apply}" in
  apply|start|reload|restart)
    remove_nft
    remove_iptables
    apply_nft
    apply_iptables
    ;;
  stop)
    remove_nft
    remove_iptables
    ;;
  *)
    echo "usage: $0 [apply|start|reload|restart|stop]" >&2
    exit 1
    ;;
esac
